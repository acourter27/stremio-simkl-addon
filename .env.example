# ─── Simkl OAuth Application Credentials ────────────────────────────────────
# Create an app at https://simkl.com/settings/developer/
SIMKL_CLIENT_ID=your_simkl_client_id_here
SIMKL_CLIENT_SECRET=your_simkl_client_secret_here

# ─── Server Configuration ─────────────────────────────────────────────────────
# Public URL where this addon is reachable (used for OAuth redirect & install links)
# No trailing slash
BASE_URL=http://localhost:7000

# Port to listen on
PORT=7000
